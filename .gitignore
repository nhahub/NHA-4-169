################################################################################
# Standard .NET Gitignore
################################################################################

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio cache and settings
.vs/
/.vs/

# Build results
[Bb]in/
[Oo]bj/
[Log]/

# Rider / JetBrains
.idea/

# Visual Studio Code
.vscode/

# Package management files
project.lock.json
project.fragment.lock.json
artifacts/

# Open environments and local config
.env
.env.local

# External tools or cache generated by Copilot/extensions
*.vsidx
*.db
*.cache
*.backup.json